generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

//-----ENUMS----------------------

enum Severity {
    LOW
    MEDIUM
    HIGH
    CRITICAL
}

enum IncidentStatus {
    OPEN
    INVESTIGATING
    IDENTIFIED
    MONITORING
    RESOLVED
}

enum ErrorStatus {
    ACTIVE
    RESOLVED
    IGNORED
}

enum EventType {
    DEPLOYMENT
    SCALING
    AUTH
    PAYMENT
    SYSTEM
    CUSTOM
}

//-----MODELS----------------------

model Incident {
    id          String         @id @default(uuid()) 
    title       String
    description String?
    severity    Severity       @default(MEDIUM)
    status      IncidentStatus @default(OPEN)
    service     String? //which service is affected
    assignee    String? //free-form for now, could FK to a user table later

    //Timestamps
    createdAt  DateTime @default(now())
    updatedAt   DateTime @updatedAt
    resolvedAt DateTime? //null until resolvedAt

    //Relations
    errors Error[] //and incident can have many linked errors
    events AppEvent[] //events that fired during this incident

    @@map("incidents") //actual table name in postgres
}

model Error {
    id          String      @id @default(uuid()) 
    message     String
    stack       String?     @db.Text
    service     String
    status      ErrorStatus @default(ACTIVE)
    count       Int         @default(1) //incremented on duplicate errors
    fingerprint String //hash of message+location for deduplication
    metadata    Json? //any extra context as Json

    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt
    resolvedAt DateTime?

    //Relations
    incidentId String?   //optional - errors exist before incidents
    incident   Incident? @relation(fields: [incidentId], references: [id])

    @@index([fingerprint])
    @@index([service])
    @@map("errors")
}

model AppEvent {
    id       String    @id @default(uuid()) 
    type     EventType
    service  String
    message  String
    payload  Json? //any extra data about the event
    severity Severity  @default(LOW)

    createdAt DateTime @default(now())

    //Optional link to an incident
    incidentId String? 
    incident   Incident? @relation(fields: [incidentId], references: [id])

    @@index([service])
    @@index([type])
    @@index([createdAt])
    @@map("app_events")
}

model Dashboard {
    id          String  @id @default(uuid()) 
    name        String
    description String?

    config    Json    @default("{}") //stores widget layout and settings as JSON
    isDefault Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("dashboards")
}
